# Copy to .env and fill in secrets: cp .env.example .env

# Required for OpenAI (reasoning + embeddings)
OPENAI_API_KEY=

# Neo4j — lokal mit Compose: neo4j://localhost:7687
# Im App-Container überschreibt docker-compose.yml mit neo4j://neo4j:7687
NEO4J_URL=neo4j://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=0123456789

# Chroma (Persistenz; im Container zeigt das Volume auf /app/chroma_store)
CHROMA_COLLECTION=migration_store
CHROMA_DIR=./chroma_store

# Modelle (optional, Defaults siehe Code)
EMBEDDING_MODEL=text-embedding-3-large
REASONING_MODEL=o4-mini
