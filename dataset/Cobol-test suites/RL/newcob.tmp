000300     RL102A.                                                      RL1024.2
000400****************************************************************  RL1024.2
000500*                                                              *  RL1024.2
000600*    VALIDATION FOR:-                                          *  RL1024.2
000700*                                                              *  RL1024.2
000800*    "ON-SITE VALIDATION, NATIONAL INSTITUTE OF STD & TECH.     ".RL1024.2
000900*                                                              *  RL1024.2
