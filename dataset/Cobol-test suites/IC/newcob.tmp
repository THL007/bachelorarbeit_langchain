000700*                                                              *  IC1054.2
000800*    "ON-SITE VALIDATION, NATIONAL INSTITUTE OF STD & TECH.     ".IC1054.2
000900*                                                              *  IC1054.2
001000*    "COBOL 85 VERSION 4.2, Apr  1993 SSVG                      ".IC1054.2
001100*                                                              *  IC1054.2
